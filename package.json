{
  "name": "cf-think-agent",
  "version": "0.1.0",
  "description": "Production-ready AI agent framework built on Cloudflare Think",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "secrets": "pwsh -File scripts/apply-secrets.ps1",
    "deploy": "npm run frontend:build && wrangler deploy",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "npm run test:coding-loop-e2e && npm run test:promotion-integration && npm run test:preview-deploy-integration && npm run build && node --test tests/*.test.mjs && npm --prefix frontend test",
    "test:preview-deploy-integration": "tsx --test src/deploy/__tests__/previewDeploy.integration.test.ts src/deploy/__tests__/previewDeployR2Verified.test.ts src/deploy/__tests__/previewDeployWitness.test.ts src/deploy/__tests__/cloudflareWorkersVersionUpload.test.ts src/deploy/__tests__/previewDeployCloudflareVersionUpload.test.ts src/deploy/__tests__/orchestratorProductionDeploy.test.ts src/deploy/__tests__/productionDeployVerified.test.ts",
    "test:codemode-wire-manual-checklist": "tsx --test src/tools/__tests__/codemodeWireManualChecklist.integration.test.ts",
    "test:coding-loop-e2e": "tsx --test src/agents/codingLoop/__tests__/codingCollaborationLoop.e2e.test.ts src/agents/codingLoop/__tests__/coordinatorCodingLoopStatelessResolve.test.ts src/agents/codingLoop/__tests__/buildSubAgentDelegationOptions.test.ts src/agents/codingLoop/__tests__/codingLoopPromptStagingPolicy.test.ts src/coordinatorControlPlane/__tests__/assembleBlueprintContextForCodingTask.test.ts src/coordinatorControlPlane/__tests__/blueprintFileStructure.test.ts src/coordinatorControlPlane/__tests__/materializeProject.test.ts src/coordinatorControlPlane/__tests__/projectFinalize.test.ts src/observability/__tests__/aiGatewayLogQuery.test.ts src/agents/__tests__/orchestratorPromotionBoundary.test.ts src/agents/__tests__/mainAgentCodemodeSanityTurn.integration.test.ts src/agents/__tests__/toolAgentSurface.integration.test.ts src/agents/__tests__/toolAgentCodemodeRelay.contract.test.ts src/agents/__tests__/toolAgentRpcIngress.test.ts src/agents/__tests__/formatDelegateToolAgentMessage.test.ts src/agents/__tests__/delegateToolTaskTurnOutcome.test.ts src/agents/__tests__/mainAgentDelegateTool.contract.test.ts src/agents/__tests__/toolAgentResultEnvelope.test.ts src/server/__tests__/webhookDispatchTurn.contract.test.ts src/agents/__tests__/mainAgentDelegateToolFailure.integration.test.ts src/agents/__tests__/mainAgentToolSurfaceReduction.test.ts src/agents/__tests__/toolAgentRolloutRegression.test.ts src/agents/__tests__/aiGatewayRouterDocs.contract.test.ts src/agents/__tests__/toolAgentLargeResultGuards.test.ts src/agents/__tests__/toolAgentThinkFacet.behavior.test.ts src/agents/__tests__/toolAgentReductionPipeline.test.ts src/debug/__tests__/projectAutonomyDefaults.test.ts src/lib/__tests__/repairInferenceToolCallHistory.test.ts src/lib/__tests__/codemodeGuidanceSettings.test.ts src/lib/__tests__/toolAgentWorkloadKind.test.ts src/lib/__tests__/toolAgentGatewayObservability.test.ts src/lib/__tests__/mcpRestoreFromPersisted.test.ts src/lib/__tests__/mcpToolAgentLiveReuse.test.ts src/lib/__tests__/mcpOAuthCallbackHost.test.ts src/tools/__tests__/toolSurfacePolicy.test.ts src/tools/__tests__/gatewayToolSurfaceAudit.test.ts src/tools/__tests__/codemodeRelayRouterSurface.integration.test.ts src/tools/__tests__/codemodeToolSurfaceCompatibility.integration.test.ts src/tools/__tests__/codemodeToolSurfaceResolve.test.ts src/tools/__tests__/codemodeSanityMerge.test.ts src/tools/__tests__/codemodeRouterPlumbing.test.ts src/tools/__tests__/codemodeRouterHelpers.test.ts src/tools/__tests__/codemodeVisibleFallback.test.ts src/models/__tests__/aiGatewayCompatFetchLifecycle.test.ts src/models/__tests__/mainAgentChatRecoveryPolicy.test.ts src/tools/__tests__/codemodeApiValidationStop.test.ts src/tools/__tests__/codemodeOpenApiExecutionPlan.test.ts src/tools/__tests__/dexCodemodeHealthRouter.integration.test.ts src/tools/__tests__/delegatedMcpRpcMirrorWire.integration.test.ts src/tools/__tests__/codemodeWireMirrorEnvelope.test.ts src/tools/__tests__/mcpLiveMirrorTools.test.ts src/tools/__tests__/codemodeWireManualChecklist.integration.test.ts src/tools/__tests__/mcpToolFeedbackParser.test.ts src/tools/__tests__/mcpToolCallFeedback.integration.test.ts",
    "test:promotion-integration": "tsx --test src/promotion/__tests__/promotionIntegration.test.ts src/promotion/__tests__/artifactPromotionR2.test.ts src/promotion/__tests__/artifactPromotionArtifacts.test.ts src/promotion/__tests__/flagshipHttp.test.ts src/promotion/__tests__/flagshipBinding.test.ts src/promotion/__tests__/previewPromotionPipeline.test.ts src/promotion/__tests__/previewPromotionWorkflowLogic.test.ts src/promotion/__tests__/previewPromotionCrossSeam.test.ts src/promotion/__tests__/promotionPlatformDiagnostics.test.ts src/promotion/__tests__/promotionOperationalStaging.test.ts src/agents/__tests__/subagentToolBoundary.test.ts",
    "diagnose:platform": "tsx src/promotion/promotionPlatformDiagnosticsCli.ts",
    "diagnose:staging": "tsx src/promotion/promotionOperationalStagingCli.ts",
    "sandbox:orchestration": "tsx src/sandbox/runOrchestrationSandbox.ts",
    "type-check:coding-loop": "tsc -p tsconfig.coding-loop-e2e.json --noEmit",
    "type-check:promotion-integration": "tsc -p tsconfig.promotion-integration.json --noEmit",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview",
    "tail": "wrangler tail",
    "tail:json": "wrangler tail --format json",
    "tail:compact": "npx wrangler tail --format json 2>&1 | node ./scripts/compact-websocket-tail.mjs"
  },
  "keywords": [
    "cloudflare",
    "think",
    "agents",
    "ai",
    "workers"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@cloudflare/ai-chat": "^0.6.2",
    "@cloudflare/codemode": "^0.3.4",
    "@cloudflare/playwright": "^1.1.1",
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/shell": "^0.3.3",
    "@cloudflare/think": "^0.4.2",
    "@cloudflare/voice": "^0.1.2",
    "@cloudflare/workers-types": "^4.20250114.0",
    "agents": "^0.12.3",
    "ai": "^6.0.0",
    "diff": "^9.0.0",
    "isomorphic-git": "^1.37.6",
    "workers-ai-provider": "^3.0.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/diff": "^7.0.2",
    "@types/node": "^20.10.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.6",
    "wrangler": "^4.86.0"
  }
}
