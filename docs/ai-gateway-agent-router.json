        "provider": "workers-ai",
        "model": "@cf/moonshotai/kimi-k2.6",
        "timeout": 90000,
        "retries": 1
      },
      "outputs": {
        "success":  { "elementId": "end" },
        "fallback": { "elementId": "brow-1" }
      }
    },
    {
      "id": "brow-1",
