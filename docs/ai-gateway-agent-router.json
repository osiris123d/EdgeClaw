{
  "name": "agent-router",
  "elements": [
    {
      "id": "start",
      "type": "start",
      "outputs": {
        "next": { "elementId": "chk-main" }
      }
    },

    {
      "id": "chk-main",
      "type": "conditional",
      "properties": {
        "conditions": {
          "metadata.agent": { "$eq": "MainAgent" }
        }
      },
      "outputs": {
        "true":  { "elementId": "main-0" },
        "false": { "elementId": "chk-coord" }
      }
    },

    {
      "id": "chk-coord",
      "type": "conditional",
      "properties": {
        "conditions": {
          "metadata.agent": { "$eq": "CoordinatorAgent" }
        }
      },
      "outputs": {
        "true":  { "elementId": "coord-0" },
        "false": { "elementId": "chk-coder" }
      }
    },

    {
      "id": "chk-coder",
      "type": "conditional",
      "properties": {
        "conditions": {
          "metadata.agent": { "$eq": "CoderAgent" }
        }
      },
      "outputs": {
        "true":  { "elementId": "coder-0" },
        "false": { "elementId": "chk-brow" }
      }
    },

    {
      "id": "chk-brow",
      "type": "conditional",
      "properties": {
        "conditions": {
          "metadata.agent": { "$eq": "BrowserAgent" }
        }
      },
      "outputs": {
        "true":  { "elementId": "brow-0" },
        "false": { "elementId": "test-0" }
      }
    },

    {
      "id": "main-0",
      "type": "model",
      "properties": {
        "provider": "workers-ai",
        "model": "@cf/zai-org/glm-4.7-flash",
        "timeout": 20000,
        "retries": 1
      },
      "outputs": {
        "success":  { "elementId": "end" },
        "fallback": { "elementId": "main-1" }
      }
    },
    {
      "id": "main-1",
      "type": "model",
      "properties": {
        "provider": "workers-ai",
        "model": "@cf/google/gemma-4-26b-a4b-it",
        "timeout": 25000,
        "retries": 1
      },
      "outputs": {
        "success":  { "elementId": "end" },
        "fallback": { "elementId": "main-2" }
      }
    },
    {
      "id": "main-2",
      "type": "model",
      "properties": {
        "provider": "workers-ai",
        "model": "@cf/meta/llama-4-scout-17b-16e-instruct",
